# ============================================
# Document Manager Mobile - Environment Variables
# ============================================
# Copy this to .env and fill in your values.

# Backend API URL (no trailing slash)
# For local dev with Expo Go on the same network: use your machine's LAN IP
# e.g. EXPO_PUBLIC_API_URL=http://192.168.1.100:8000
EXPO_PUBLIC_API_URL=http://localhost:8000

# ============================================
# Stack Auth Configuration
# ============================================
# From https://app.stack-auth.com → your project → API Keys
EXPO_PUBLIC_STACK_PROJECT_ID=your-project-id
EXPO_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY=your-publishable-client-key

# Optional: override Stack Auth API base URL
# EXPO_PUBLIC_STACK_AUTH_URL=https://api.stack-auth.com
