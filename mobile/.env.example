# ============================================
# Document Manager Mobile - Environment Variables
# ============================================
# Copy this to .env and fill in your values.

# Backend API URL (no trailing slash)
# For local dev with Expo Go on the same network: use your machine's LAN IP
# e.g. EXPO_PUBLIC_API_URL=http://192.168.1.100:8000
# Production: EXPO_PUBLIC_API_URL=https://smartsearchapi.nextscholar.site
EXPO_PUBLIC_API_URL=http://localhost:8000

# ============================================
# Stack Auth Configuration
# ============================================
# From https://app.stack-auth.com → your project → API Keys
EXPO_PUBLIC_STACK_PROJECT_ID=your-project-id
EXPO_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY=your-publishable-client-key

# Override Stack Auth API base URL (defaults to https://api.stack-auth.com)
# Production: EXPO_PUBLIC_STACK_AUTH_URL=https://authapi.nextscholar.site
# EXPO_PUBLIC_STACK_AUTH_URL=https://api.stack-auth.com

# HTTPS redirect URI for OAuth (Stack Auth and Google require HTTPS).
# The web app hosts a relay page at this URL that forwards the OAuth code to
# the app's custom URL scheme (document-manager://auth/callback).
# Production value is pre-filled; override for local dev if needed.
EXPO_PUBLIC_OAUTH_REDIRECT_URI=https://smartsearch.nextscholar.site/auth/callback
