{
  "expo": {
    "name": "Document Manager",
    "slug": "document-manager",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0F0F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.documentmanager.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Allow Document Manager to access your photos to upload documents.",
        "NSCameraUsageDescription": "Allow Document Manager to use the camera to capture documents.",
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": ["document-manager"]
          }
        ],
        "CFBundleDocumentTypes": [
          {
            "CFBundleTypeName": "All Files",
            "LSHandlerRank": "Alternate",
            "LSItemContentTypes": ["public.content", "public.data"]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F0F0F"
      },
      "package": "com.documentmanager.app",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "document-manager"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        },
        {
          "action": "SEND",
          "category": ["DEFAULT"],
          "data": [
            { "mimeType": "*/*" }
          ]
        },
        {
          "action": "SEND_MULTIPLE",
          "category": ["DEFAULT"],
          "data": [
            { "mimeType": "*/*" }
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Document Manager to access your photos.",
          "cameraPermission": "Allow Document Manager to use the camera."
        }
      ],
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "scheme": "document-manager"
  }
}
