{
  "cli": {
    "version": ">= 13.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://smartsearchapi.nextscholar.site",
        "EXPO_PUBLIC_STACK_AUTH_URL": "https://authapi.nextscholar.site"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "env": {
        "EXPO_PUBLIC_API_URL": "https://smartsearchapi.nextscholar.site",
        "EXPO_PUBLIC_STACK_AUTH_URL": "https://authapi.nextscholar.site"
      },
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {
        "resourceClass": "m-medium"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
